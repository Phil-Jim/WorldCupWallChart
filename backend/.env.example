# Get a free key at https://www.football-data.org/
FOOTBALL_DATA_KEY=your_key_here

# Optional — override the World Cup competition id (default 2000).
# football-data.org uses 2000 = FIFA World Cup.
COMPETITION_ID=2000

# Optional — cache TTL in seconds. The chart polls every 60s; we cache
# upstream responses for a bit longer to stay well under the 10 req/min limit.
CACHE_TTL_SECONDS=120

# Optional — port (Railway provides PORT automatically).
PORT=8080

# Optional — comma-separated origins allowed via CORS. Default is "*".
ALLOWED_ORIGINS=*
